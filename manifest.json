{
   "action": {
      "default_icon": "icons/logo_anatole_light.png"
   },
   "background": {
      "service_worker": "background.js"
   },
   "content_scripts": [ {
      "js": [ "content.js" ],
      "matches": [ "https://www.google.com/*", "https://www.google.fr/*" ]
   } ],
   "description": "Informe l'utilisateur si le lien survolé est un site officiel lorsqu'il effectue une recherche pour des démarches administratives.",
   "homepage_url": "https://www.anatole-extension.fr",
   "host_permissions": [ "https://www.google.com/*", "https://www.google.fr/*" ],
   "icons": {
      "128": "icons/icon-light-128.png",
      "16": "icons/icon-light-16.png",
      "48": "icons/icon-light-48.png"
   },
   "key": "",
   "manifest_version": 3,
   "name": "Anatole",
   "update_url": "https://edge.microsoft.com/extensionwebstorebase/v1/crx",
   "version": "1.1.1",
   "web_accessible_resources": [ {
      "matches": [ "https://www.google.com/*", "https://www.google.fr/*" ],
      "resources": [ "welcome.html" ]
   } ]
}
